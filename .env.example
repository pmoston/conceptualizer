DOCKER_NETWORK=conceptualizer-net
# For local dev use localhost; Docker overrides this to the container hostname
APP_HOST=conceptualizer-app
DB_HOST=conceptualizer-db

POSTGRES_USER=conceptualizer
POSTGRES_PASSWORD=change-me
POSTGRES_DB=conceptualizer
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:5432/${POSTGRES_DB}

AUTH_PASSWORD=your-portal-password
AUTH_SECRET=your-32-char-session-secret-here

ANTHROPIC_API_KEY=sk-ant-...

# Converter microservice URL.
# In docker-compose this is set to http://conceptualizer-converter:3001 automatically.
# For local dev (npm run dev), add the line below to .env.local after starting the
# converter container: CONVERTER_URL=http://localhost:3001
CONVERTER_URL=http://conceptualizer-converter:3001

# Optional: Ollama for local model inference (defaults to http://localhost:11434/api)
# OLLAMA_BASE_URL=http://localhost:11434/api

# Local Ollama models are used by default (see src/lib/models.ts for per-agent mapping).
# Set to "true" to use Claude API instead.
# USE_CLOUD_MODELS=true

# Microsoft Learn MCP server for fact-check agent (official docs lookup).
# Obtain the SSE endpoint URL from https://github.com/MicrosoftDocs/mcp
MSDOCS_MCP_URL=https://learn.microsoft.com/api/mcp
