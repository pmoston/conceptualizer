DOCKER_NETWORK=conceptualizer-net
# For local dev use localhost; Docker overrides this to the container hostname
APP_HOST=conceptualizer-app
DB_HOST=conceptualizer-db

POSTGRES_USER=conceptualizer
POSTGRES_PASSWORD=change-me
POSTGRES_DB=conceptualizer
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:5432/${POSTGRES_DB}

AUTH_PASSWORD=your-portal-password
AUTH_SECRET=your-32-char-session-secret-here

ANTHROPIC_API_KEY=sk-ant-...

# HubSpot portal ID — find it in any HubSpot URL: app.hubspot.com/contacts/{PORTAL_ID}/...
# Used to generate deep links to HubSpot records; links are hidden if unset
HUBSPOT_PORTAL_ID=

# Optional: Ollama for local model inference (defaults to http://localhost:11434/api)
# OLLAMA_BASE_URL=http://localhost:11434/api
