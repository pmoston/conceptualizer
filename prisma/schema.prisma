generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Customer {
  id          String    @id @default(cuid())
  hubspotId   String?   @unique
  name        String
  domain      String?
  industry    String?
  contacts    Contact[]
  deals       Deal[]
  projects    Project[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Contact {
  id          String   @id @default(cuid())
  hubspotId     String?  @unique
  academicTitle String?
  firstName     String
  lastName      String
  email         String?
  jobTitle      String?
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Deal {
  id           String     @id @default(cuid())
  hubspotId    String?    @unique
  name         String
  stage        String?
  amount       Float?
  currency     String?
  closeDate    DateTime?
  ownerName    String?
  customer     Customer   @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId   String
  projects     Project[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Project {
  id          String        @id @default(cuid())
  title       String
  language    Language      @default(EN)
  status      ProjectStatus @default(DRAFT)
  description String?
  customer    Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId  String
  deal        Deal?         @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId      String?
  documents   Document[]
  agentRuns   AgentRun[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Document {
  id          String       @id @default(cuid())
  name        String
  type        DocumentType
  filePath    String
  mimeType    String
  sizeBytes   Int
  previewPath  String?
  previewError String?
  ocrText      String?
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  createdAt   DateTime     @default(now())
}

model AgentRun {
  id          String             @id @default(cuid())
  agentName   String
  status      AgentStatus        @default(PENDING)
  input       Json
  output      String?
  error       String?
  steps       AgentStep[]
  messages    AgentMessage[]
  auditLogs   WorkflowAuditLog[]
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  startedAt   DateTime           @default(now())
  completedAt DateTime?
}

model WorkflowAuditLog {
  id        String   @id @default(cuid())
  runId     String
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  iteration Int      @default(0)
  phase     String
  verdict   String?
  details   String?
  createdAt DateTime @default(now())
}

model AgentMessage {
  id        String      @id @default(cuid())
  runId     String
  run       AgentRun    @relation(fields: [runId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String
  createdAt DateTime    @default(now())
}

model AgentStep {
  id        String   @id @default(cuid())
  runId     String
  run       AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  index     Int
  type      StepType
  label     String
  content   String?
  createdAt DateTime @default(now())
}

enum Language {
  EN
  DE
}

enum ProjectStatus {
  DRAFT
  IN_PROGRESS
  REVIEW
  DONE
}

enum DocumentType {
  SOURCE_MATERIAL
  DRAFT
  FINAL
  SUPPORTING
}

enum AgentStatus {
  PENDING
  RUNNING
  AWAITING_INPUT
  COMPLETED
  FAILED
}

enum MessageRole {
  USER
  AGENT
}

enum StepType {
  INFO
  AGENT_CALL
  AGENT_OUTPUT
  TOOL_CALL
  TOOL_RESULT
  WARNING
  ERROR
}
